# ═══════════════════════════════════════════════════════════════════════════════
# LIVE API TESTING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
#
# This file contains template credentials for live API testing of BusinessOS actions.
# Copy this to .env.test.local and fill in your actual credentials.
#
# SECURITY: .env.test.local is gitignored - never commit real credentials!
#
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# GOOGLE APIs (Gmail + Calendar)
# ───────────────────────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com/apis/credentials
# Scopes needed:
#   - https://www.googleapis.com/auth/gmail.send
#   - https://www.googleapis.com/auth/gmail.readonly
#   - https://www.googleapis.com/auth/calendar
#   - https://www.googleapis.com/auth/calendar.events

GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token
GOOGLE_TEST_EMAIL=your-email@gmail.com

# ───────────────────────────────────────────────────────────────────────────────
# SLACK
# ───────────────────────────────────────────────────────────────────────────────
# Setup: https://api.slack.com/apps
# Scopes needed: chat:write, channels:read, users:read

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_TEST_CHANNEL_ID=C01234567
SLACK_TEST_CHANNEL_NAME=test-businessos

# ───────────────────────────────────────────────────────────────────────────────
# NOTION
# ───────────────────────────────────────────────────────────────────────────────
# Setup: https://www.notion.so/my-integrations
# Create internal integration, share test database with it

NOTION_API_KEY=secret_your-notion-integration-token
NOTION_TEST_DATABASE_ID=your-database-id-32-chars
NOTION_TEST_PAGE_ID=your-page-id-32-chars

# ───────────────────────────────────────────────────────────────────────────────
# LINEAR
# ───────────────────────────────────────────────────────────────────────────────
# Setup: https://linear.app/settings/api
# Create Personal API key

LINEAR_API_KEY=lin_api_your-linear-api-key
LINEAR_TEST_TEAM_ID=YOUR-TEAM-KEY
LINEAR_TEST_PROJECT_ID=uuid-of-test-project

# ───────────────────────────────────────────────────────────────────────────────
# HUBSPOT
# ───────────────────────────────────────────────────────────────────────────────
# Setup: https://app.hubspot.com/private-apps
# Scopes: crm.objects.contacts.write, crm.objects.contacts.read

HUBSPOT_API_KEY=pat-na1-your-private-app-token
HUBSPOT_TEST_CONTACT_EMAIL=test@businessos.test

# ───────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS
# ───────────────────────────────────────────────────────────────────────────────
# Testing AI actions requires at least one provider

ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk_your-groq-key

# ───────────────────────────────────────────────────────────────────────────────
# BUSINESSOS BACKEND (for BusinessOS-specific actions)
# ───────────────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://user:pass@localhost:5432/businessos_test?sslmode=disable
REDIS_URL=redis://localhost:6379/1
SECRET_KEY=test-secret-key-32-characters-min
TOKEN_ENCRYPTION_KEY=test-encryption-key-32-chars

# ───────────────────────────────────────────────────────────────────────────────
# TEST CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

# Which action categories to test (comma-separated)
# Options: gmail,calendar,slack,notion,linear,hubspot,ai,transform,businessos,all
TEST_CATEGORIES=all

# Cleanup mode: always, never, on_success
TEST_CLEANUP_MODE=on_success

# Verbose output
TEST_VERBOSE=true

# ═══════════════════════════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:
#    cp .env.test .env.test.local
#
# 2. Fill in credentials for services you want to test
#
# 3. Run OAuth setup helper (for Google):
#    go run backend/scripts/oauth_setup_helper.go
#
# 4. Run tests:
#    go run backend/scripts/test_live_actions.go
#    # Or specific categories:
#    go run backend/scripts/test_live_actions.go --categories=gmail,slack
#
# ═══════════════════════════════════════════════════════════════════════════════

# =============================================================================
# BusinessOS — Root .env Template
# Copy to .env:  cp .env.example .env
# Then fill in the values below before running:  docker compose up -d
#
# For the full key reference with setup links, see:
#   desktop/backend-go/.env.example
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                  # REQUIRED — openssl rand -base64 32
POSTGRES_DB=business_os
POSTGRES_PORT=5432                  # host port (change if 5432 is taken)

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                     # REQUIRED — openssl rand -base64 32
REDIS_PORT=6379                     # host port

# -----------------------------------------------------------------------------
# Security keys — generate all of these before running in any shared env
# -----------------------------------------------------------------------------
# openssl rand -base64 64
SECRET_KEY=

# openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# openssl rand -base64 32
REDIS_KEY_HMAC_SECRET=

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
ENVIRONMENT=development
BACKEND_PORT=8001

# -----------------------------------------------------------------------------
# AI Provider
# Default: ollama_local (no key needed if Ollama is running on the host).
# Set AI_PROVIDER=anthropic and ANTHROPIC_API_KEY to use Claude instead.
# -----------------------------------------------------------------------------
AI_PROVIDER=ollama_local
OLLAMA_LOCAL_URL=http://host.docker.internal:11434
DEFAULT_MODEL=llama3.2:3b

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
# PUBLIC_API_URL is baked into the Vite bundle at build time.
# It must be the externally-reachable URL of the backend.
PUBLIC_API_URL=http://localhost:8001
# VITE_API_URL is the runtime path used for server-side fetches in SvelteKit.
VITE_API_URL=http://localhost:8001/api
VITE_BACKEND_URL=http://localhost:8001
# SvelteKit CSRF: must match the URL users browse to.
ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# OSA Integration (optional — leave OSA_ENABLED=false for local-only mode)
# -----------------------------------------------------------------------------
OSA_ENABLED=false
OSA_MODE=local
MIOSA_API_KEY=

# YAWL v6 Engine (optional — required for conformance checking + WCP patterns)
YAWLV6_URL=http://localhost:8080
YAWLV6_SPECS_PATH=~/yawlv6/exampleSpecs

# -----------------------------------------------------------------------------
# OAuth Integrations (all optional — leave blank to skip)
# Full setup instructions: desktop/backend-go/.env.example
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8001/api/auth/microsoft/callback

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8001/api/auth/slack/callback
SLACK_SIGNING_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8001/api/auth/notion/callback

HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8001/api/auth/hubspot/callback

LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:8001/api/auth/linear/callback

CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:8001/api/auth/clickup/callback

AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=
AIRTABLE_REDIRECT_URI=http://localhost:8001/api/auth/airtable/callback

# -----------------------------------------------------------------------------
# Web Push (optional)
# Generate keys:  npx web-push generate-vapid-keys
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

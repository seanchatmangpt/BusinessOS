# ==============================================================================
# BusinessOS Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values
# SECURITY: Never commit .env to git! It contains secrets.

# ==============================================================================
# DATABASE
# ==============================================================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=MODE
DATABASE_URL=postgresql://postgres:password@localhost:5432/businessos?sslmode=disable

# ==============================================================================
# SERVER
# ==============================================================================
# Port the backend server listens on
SERVER_PORT=8001

# Environment: development, staging, production
ENVIRONMENT=development

# Allowed CORS origins (comma-separated)
# SECURITY WARNING: In production, MUST be exact domains - NEVER use wildcard (*)
# Wildcard origins with credentials enable CSRF attacks
# Production example: ALLOWED_ORIGINS=https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ==============================================================================
# SECURITY (CRITICAL - CHANGE THESE!)
# ==============================================================================
# SECRET_KEY: Used for JWT token signing
# Generate with: openssl rand -base64 32
SECRET_KEY=change-this-to-random-string-min-32-chars

# TOKEN_ENCRYPTION_KEY: Used for encrypting OAuth tokens in database
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# ==============================================================================
# REDIS
# ==============================================================================
# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis password (optional for local dev, required for production)
REDIS_PASSWORD=changeme_insecure_dev_password

# ==============================================================================
# AI PROVIDER
# ==============================================================================
# AI provider: ollama_local, ollama_cloud, anthropic, groq
AI_PROVIDER=ollama_local

# Ollama URLs
OLLAMA_LOCAL_URL=http://localhost:11434
OLLAMA_CLOUD_URL=https://api.ollama.com

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Groq API
GROQ_API_KEY=gsk_...
GROQ_MODEL=mixtral-8x7b-32768

# Default model to use
DEFAULT_MODEL=llama3.2:3b

# ==============================================================================
# OAUTH INTEGRATIONS (Optional)
# ==============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/integrations/google/callback

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:8001/api/integrations/slack/callback

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8001/api/integrations/github/callback

# ==============================================================================
# DOCKER (Optional - for containerized terminals)
# ==============================================================================
# Enable Docker container terminals
DOCKER_ENABLED=false

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# ==============================================================================
# LOGGING
# ==============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=text

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
# Enable conversation summary background job
CONVERSATION_SUMMARY_JOB_ENABLED=false

# Enable behavior patterns detection
BEHAVIOR_PATTERNS_JOB_ENABLED=false

# Enable app profiler sync job
APP_PROFILER_SYNC_JOB_ENABLED=false

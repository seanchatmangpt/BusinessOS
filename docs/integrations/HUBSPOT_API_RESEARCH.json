  "syncing_best_practices": {
    "data_consistency": [
      "Use email as primary identifier for contacts (prevents duplicates)",
      "Implement deduplication logic before creating contacts",
      "Store HubSpot object IDs for all synced records",
      "Maintain mapping between BusinessOS IDs and HubSpot IDs"
    ],
    "performance_optimization": [
      "Cache property definitions (contact, company, deal properties) and refresh periodically",
      "Use batch endpoints for bulk operations (up to 100 records per request)",
      "Implement exponential backoff for rate limit handling (429 responses)",
      "Schedule bulk syncs during off-peak hours",
      "Store pagination cursors to resume interrupted syncs"
    ],
    "real_time_updates": [
      "Use webhooks for real-time event notifications (Enterprise plans)",
      "Subscribe to: object creation, object deletion, property changes",
      "Webhooks do NOT count toward rate limits (Enterprise)",
      "Implement webhook signature verification for security",
      "Queue webhook events for processing to avoid timeout issues"

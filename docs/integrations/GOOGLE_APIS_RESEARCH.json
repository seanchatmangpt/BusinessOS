                "gadget": "object (deprecated)",
                "privateCopy": "boolean",
                "locked": "boolean",
                "source": {
                  "title": "string",
                  "url": "string"
                },
                "attachments": [
                  {
                    "fileUrl": "string",
                    "title": "string",
                    "mimeType": "string",
                    "iconLink": "string",
                    "fileId": "string"
                  }
                ],
                "colorId": "string (1-11, maps to calendar colors)",
                "htmlLink": "string",
                "kind": "calendar#event"
              }
            ]
          }
        },
        "events_insert": {
          "method": "POST",
          "path": "/calendars/{calendarId}/events",
          "description": "Create a new calendar event",
          "request_body": "Event object (see events_list returns for fields)",
          "query_parameters": {
            "supportsAttachments": "boolean",
            "conferenceDataVersion": "0 or 1 (required for Meet/video links)",
            "maxAttendees": "integer"
          }
        },
        "events_update": {
          "method": "PUT",
          "path": "/calendars/{calendarId}/events/{eventId}",
          "description": "Update an existing event",
          "query_parameters": {
            "supportsAttachments": "boolean",
            "conferenceDataVersion": "0 or 1",
            "maxAttendees": "integer"
          }
        },
        "events_delete": {
          "method": "DELETE",
          "path": "/calendars/{calendarId}/events/{eventId}",
          "description": "Delete an event"
        }
      },
      "rate_limits": {
        "free_tier": "1,000,000 queries per day",
        "quota_units": "Per API call complexity varies",
        "rate_per_second": "No strict per-second limit but fair use applies"
      },
      "sync_strategy": {
        "initial_sync": {
          "recommended_approach": "Fetch all calendars, then events from each",
          "time_window": "Last 6 months to +6 months is optimal",
          "pagination": "Use pageToken for large result sets",
          "estimated_time": "5-10 minutes for typical user"
        },
        "incremental_sync": {
          "approach": "Use updatedMin parameter",
          "frequency": "Daily or hourly is typical",
          "watch_api": "Available for push-based changes (requires webhook)",
          "challenge": "Handles recurring event expansions automatically with singleEvents=true"
        }
      },
      "key_data_fields": [
        "Event ID (immutable identifier)",
        "Summary/Title",
        "Description/Notes",
        "Location",
        "Start/End times with timezone",
        "All-day indicator",
        "Status (confirmed/tentative/cancelled)",
        "Attendees (with names, emails, RSVP status)",
        "Organizer info",
        "Recurrence rules (RRULE format)",
        "Meeting links (conferenceData - Google Meet, Zoom, Teams)",
        "Reminders (email, popup, sms)",
        "Color ID (visual organization)",
        "Attachments (files, links)",
        "Event type (working location, focus time, out of office)",
        "Transparency (busy/free)",
        "Visibility (public/private/confidential)",
        "Created/Updated timestamps"
      ],
      "businessos_mapping": {
        "calendar_module": "Primary integration point",
        "daily_log": "Auto-populate with day's events",
        "tasks": "Convert events to tasks if needed",
        "nodes": "Each event becomes a node",
        "estimated_nodes": "20-100 per initial sync"
      },
      "current_implementation": {
        "file": "/Users/rhl/Desktop/BusinessOS2/desktop/backend-go/internal/integrations/google/calendar.go",
        "status": "Partially implemented",
        "features": [
          "SyncEvents - fetches events within date range",
          "CreateEvent - creates local and pushes to Google",
          "DeleteEvent - deletes from both local and Google",
          "GetEvents - retrieves from local database",
          "FetchEvents - native Google types for MCP",
          "CreateGoogleEvent - full feature support",
          "UpdateGoogleEvent - full feature support"
        ],
        "missing_features": [
          "Event update via UI",
          "Full attendee management",
          "Recurring event expansion details",
          "Watch API (push-based sync)",
          "Multi-calendar sync (only primary)"
        ]
      }
    },
    "gmail_v1": {
      "name": "Gmail API v1",
      "documentation_url": "https://developers.google.com/gmail/api",
      "authentication": "OAuth 2.0",
      "base_url": "https://www.googleapis.com/gmail/v1",
      "primary_use_cases": [
        "Sync incoming emails",
        "Extract email content and metadata",
        "Parse attachments",
        "Search emails with powerful query syntax",
        "Send emails",
        "Manage labels and folders",
        "Track conversation threads",
        "Extract sender/recipient info for contacts",

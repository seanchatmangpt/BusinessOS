            "size": "integer (bytes)",
            "data": "string (base64-encoded file content)"
          }
        },
        "users_threads_list": {
          "method": "GET",
          "path": "/users/{userId}/threads",
          "description": "List conversation threads",
          "query_parameters": {
            "q": "Gmail search query",
            "maxResults": "integer, max 500",
            "pageToken": "string"
          }
        },
        "users_threads_get": {
          "method": "GET",
          "path": "/users/{userId}/threads/{id}",
          "description": "Get full thread with all messages",
          "query_parameters": {
            "format": "full|minimal"
          }
        },
        "users_labels_list": {
          "method": "GET",
          "path": "/users/{userId}/labels",
          "description": "List all labels",
          "returns": {
            "labels": [
              {
                "id": "string",

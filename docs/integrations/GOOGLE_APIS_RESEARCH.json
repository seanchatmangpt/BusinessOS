            "addLabelIds": ["STARRED", "IMPORTANT"],
            "removeLabelIds": ["UNREAD", "INBOX"]
          }
        },
        "users_messages_trash": {
          "method": "POST",
          "path": "/users/{userId}/messages/{id}/trash",
          "description": "Move message to trash"
        },
        "users_messages_delete": {
          "method": "DELETE",
          "path": "/users/{userId}/messages/{id}",
          "description": "Permanently delete a message (cannot be undone)"

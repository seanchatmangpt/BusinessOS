            "timeMax": "RFC3339 timestamp",
            "maxResults": "integer, default 25, max 2500",
            "singleEvents": "boolean (expand recurring events)",
            "orderBy": "startTime or updated",
            "q": "search query string"
          },
          "returns": {
            "items": [
              {
                "kind": "calendar#event",
                "etag": "string",
                "id": "string",
                "created": "RFC3339 timestamp",
                "updated": "RFC3339 timestamp",
                "summary": "string",
                "description": "string",
                "location": "string",
                "start": {
                  "dateTime": "RFC3339 (timed events)",
                  "date": "YYYY-MM-DD (all-day events)",
                  "timeZone": "string"
                },
                "end": {
                  "dateTime": "RFC3339",
                  "date": "YYYY-MM-DD",
                  "timeZone": "string"
                },
                "status": "confirmed|tentative|cancelled",

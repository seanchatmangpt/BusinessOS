                  ]
                },
                "eventType": "default|outOfOffice|focusTime|workingLocation",
                "workingLocationProperties": {
                  "type": "homeOffice|officeLocation|customLocation",
                  "customLocation": {
                    "label": "string"
                  },
                  "officeLocation": {
                    "buildingId": "string",
                    "label": "string",
                    "floorId": "string",
                    "floorLabel": "string",
                    "deskId": "string",
                    "deskLabel": "string"
                  }
                },

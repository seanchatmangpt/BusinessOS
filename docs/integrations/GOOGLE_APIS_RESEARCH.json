                  }
                ],
                "organizer": {
                  "email": "string",
                  "displayName": "string",
                  "self": "boolean"
                },
                "recurrence": [
                  "RRULE:FREQ=DAILY;COUNT=5",
                  "EXDATE:20230101,20230102"
                ],
                "recurringEventId": "string",
                "originalStartTime": "RFC3339 timestamp (for recurring instances)",
                "transparency": "opaque|transparent",
                "visibility": "public|private|confidential",
                "iCalUID": "string",
                "sequence": "integer",
                "hangoutLink": "string (deprecated, use conferenceData)",
                "conferenceData": {
                  "createRequest": {
                    "requestId": "string",
                    "conferenceSolutionKey": {
                      "type": "eventType (hangoutsMeet, addOnType, etc.)"
                    }
                  },
                  "entryPoints": [
                    {
                      "entryPointType": "video|phone|more",
                      "uri": "string (the actual link)",
                      "label": "string",
                      "pin": "string",
                      "accessCode": "string",
                      "meetingCode": "string",
                      "passcode": "string"
                    }
                  ],
                  "conferenceSolution": {
                    "key": {
                      "type": "eventType"
                    },
                    "name": "Google Meet|Zoom|Teams|etc.",

        "https://www.googleapis.com/auth/gmail.settings.basic",
        "https://www.googleapis.com/auth/gmail.settings.sharing"
      ],
      "endpoints": {
        "users_messages_list": {
          "method": "GET",
          "path": "/users/{userId}/messages",
          "userId": "me (authenticated user)",
          "description": "List message IDs in a mailbox",
          "query_parameters": {
            "q": "Gmail search query (complex filtering)",
            "maxResults": "integer, max 500",
            "pageToken": "string for pagination",
            "labelIds": "array of label IDs to filter"
          },
          "returns": {
            "messages": [
              {
                "id": "string (unique message ID)",
                "threadId": "string"
              }
            ],
            "nextPageToken": "string"
          },
          "search_syntax_examples": [
            "in:inbox",
            "in:sent",
            "in:draft",
            "is:unread",
            "is:starred",
            "from:example@example.com",
            "to:example@example.com",
            "subject:important",
            "has:attachment",
            "before:2023-01-01",
            "after:2023-01-01",
            "larger:1000000",
            "filename:pdf"
          ]
        },
        "users_messages_get": {
          "method": "GET",
          "path": "/users/{userId}/messages/{id}",
          "description": "Get full message details",
          "query_parameters": {
            "format": "full|minimal|raw",
            "metadataHeaders": "array of header names to include"
          },
          "returns": {
            "id": "string",
            "threadId": "string",
            "labelIds": [
              "INBOX",
              "SENT",
              "DRAFT",
              "STARRED",
              "IMPORTANT",
              "UNREAD",
              "TRASH",
              "SPAM",
              "CATEGORY_PERSONAL",
              "CATEGORY_SOCIAL",
              "CATEGORY_PROMOTIONS",
              "CATEGORY_UPDATES",
              "CATEGORY_FORUMS",
              "CUSTOM_LABEL_ID"
            ],
            "snippet": "string (preview text)",
            "internalDate": "milliseconds since epoch",
            "payload": {
              "mimeType": "text/plain|text/html|multipart/alternative|multipart/mixed",
              "filename": "string (if attachment)",
              "headers": [
                {
                  "name": "From|To|Cc|Bcc|Subject|Date|Reply-To|Content-Type|etc.",
                  "value": "string"
                }
              ],
              "body": {
                "size": "integer",
                "data": "string (base64-encoded content)",
                "attachmentId": "string (for attachments)"
              },
              "parts": [
                "nested parts for multipart messages"
              ]
            },
            "sizeEstimate": "integer (bytes)"
          }
        },
        "users_messages_send": {
          "method": "POST",
          "path": "/users/{userId}/messages/send",
          "description": "Send an email message",
          "request_body": {
            "raw": "string (base64-encoded RFC 2822 formatted message)"
          },
          "returns": {
            "id": "string (message ID)",
            "threadId": "string"
          }
        },
        "users_messages_modify": {
          "method": "POST",
          "path": "/users/{userId}/messages/{id}/modify",
          "description": "Modify labels, mark read/unread, star/unstar, archive",

<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Object" prefix="obj" uri="http://www.xes-standard.org/object.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="consolidate_001"/>
    <event>
      <string key="concept:name" value="merge_shipments"/>
      <date key="time:timestamp" value="2024-01-01T14:00:00.000Z"/>
      <string key="obj:source_object_id" value="ship_001"/>
      <string key="obj:target_object_id" value="consolidated_001"/>
    </event>
    <event>
      <string key="concept:name" value="merge_shipments"/>
      <date key="time:timestamp" value="2024-01-01T14:05:00.000Z"/>
      <string key="obj:source_object_id" value="ship_002"/>
      <string key="obj:target_object_id" value="consolidated_001"/>
    </event>
    <event>
      <string key="concept:name" value="merge_shipments"/>
      <date key="time:timestamp" value="2024-01-01T14:10:00.000Z"/>
      <string key="obj:source_object_id" value="ship_003"/>
      <string key="obj:target_object_id" value="consolidated_001"/>
    </event>
  </trace>
</log>
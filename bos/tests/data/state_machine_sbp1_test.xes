<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="loan_001"/>
    <event>
      <string key="concept:name" value="enter_submitted"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_under_review"/>
      <date key="time:timestamp" value="2024-01-01T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_approved"/>
      <date key="time:timestamp" value="2024-01-01T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="enter_closed"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
    </event>
  </trace>
</log>
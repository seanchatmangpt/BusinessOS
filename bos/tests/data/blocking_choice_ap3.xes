      <string key="concept:name" value="appraisal_result_event"/>
      <date key="time:timestamp" value="2024-01-06T14:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="approved"/>
      <date key="time:timestamp" value="2024-01-06T14:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="funds_disbursed"/>
      <date key="time:timestamp" value="2024-01-06T15:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 3: Wait for appraisal → rejected -->
  <trace>
    <string key="concept:name" value="loan_003"/>
    <event>
      <string key="concept:name" value="application_submitted"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="wait_for_appraisal"/>
      <date key="time:timestamp" value="2024-01-03T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="appraisal_result_event"/>
      <date key="time:timestamp" value="2024-01-07T14:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="rejected"/>
      <date key="time:timestamp" value="2024-01-07T14:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="appeal_notification_sent"/>
      <date key="time:timestamp" value="2024-01-07T15:00:00.000Z"/>

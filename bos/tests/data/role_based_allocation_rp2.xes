<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
    <string key="org:role" value="role"/>
  </global>
  <!-- Trace 1: Manager1 reviews application -->
  <trace>
    <string key="concept:name" value="app_001"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-01T09:30:00.000Z"/>
      <string key="org:resource" value="manager1"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="manager1"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
  <!-- Trace 2: Manager2 (different resource, same role) reviews application -->
  <trace>
    <string key="concept:name" value="app_002"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-01T10:45:00.000Z"/>
      <string key="org:resource" value="manager2"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-01T11:15:00.000Z"/>
      <string key="org:resource" value="manager2"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
  <!-- Trace 3: Manager3 reviews application -->
  <trace>
    <string key="concept:name" value="app_003"/>
    <event>
      <string key="concept:name" value="submit_application"/>
      <date key="time:timestamp" value="2024-01-02T09:00:00.000Z"/>
      <string key="org:resource" value="applicant"/>
      <string key="org:role" value="customer"/>
    </event>
    <event>
      <string key="concept:name" value="review_application"/>
      <date key="time:timestamp" value="2024-01-02T09:45:00.000Z"/>
      <string key="org:resource" value="manager3"/>
      <string key="org:role" value="manager"/>
    </event>
    <event>
      <string key="concept:name" value="approve_or_reject"/>
      <date key="time:timestamp" value="2024-01-02T10:30:00.000Z"/>
      <string key="org:resource" value="manager3"/>
      <string key="org:role" value="manager"/>
    </event>
  </trace>
</log>
<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Org" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <!-- Trace 1: Level 1 direct resolution -->
  <trace>
    <string key="concept:name" value="ticket_001"/>
    <event>
      <string key="concept:name" value="enter_level_1"/>
      <date key="time:timestamp" value="2024-01-01T08:00:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-01T08:30:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="resolve_ticket"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="ticket_resolved"/>
      <date key="time:timestamp" value="2024-01-01T09:15:00.000Z"/>
      <string key="org:resource" value="system"/>
    </event>
  </trace>
  <!-- Trace 2: One escalation (L1 → L2 → resolved) -->
  <trace>
    <string key="concept:name" value="ticket_002"/>
    <event>
      <string key="concept:name" value="enter_level_1"/>
      <date key="time:timestamp" value="2024-01-02T08:00:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-02T08:30:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_2"/>
      <date key="time:timestamp" value="2024-01-02T09:00:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_2"/>
      <date key="time:timestamp" value="2024-01-02T09:15:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-02T10:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="resolve_ticket"/>
      <date key="time:timestamp" value="2024-01-02T11:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="ticket_resolved"/>
      <date key="time:timestamp" value="2024-01-02T11:30:00.000Z"/>
      <string key="org:resource" value="system"/>
    </event>
  </trace>
  <!-- Trace 3: Two escalations (L1 → L2 → L3 → resolved) -->
  <trace>
    <string key="concept:name" value="ticket_003"/>
    <event>
      <string key="concept:name" value="enter_level_1"/>
      <date key="time:timestamp" value="2024-01-03T08:00:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-03T08:30:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_2"/>
      <date key="time:timestamp" value="2024-01-03T09:00:00.000Z"/>
      <string key="org:resource" value="support_l1_a"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_2"/>
      <date key="time:timestamp" value="2024-01-03T09:15:00.000Z"/>
      <string key="org:resource" value="support_l2_b"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
      <string key="org:resource" value="support_l2_b"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_3"/>
      <date key="time:timestamp" value="2024-01-03T11:00:00.000Z"/>
      <string key="org:resource" value="support_l2_b"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_3"/>
      <date key="time:timestamp" value="2024-01-03T11:30:00.000Z"/>
      <string key="org:resource" value="support_l3_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-03T12:30:00.000Z"/>
      <string key="org:resource" value="support_l3_a"/>
    </event>
    <event>
      <string key="concept:name" value="resolve_ticket"/>
      <date key="time:timestamp" value="2024-01-03T14:00:00.000Z"/>
      <string key="org:resource" value="support_l3_a"/>
    </event>
    <event>
      <string key="concept:name" value="ticket_resolved"/>
      <date key="time:timestamp" value="2024-01-03T14:30:00.000Z"/>
      <string key="org:resource" value="system"/>
    </event>
  </trace>
  <!-- Trace 4: Three escalations (L1 → L2 → L3 → external) -->
  <trace>
    <string key="concept:name" value="ticket_004"/>
    <event>
      <string key="concept:name" value="enter_level_1"/>
      <date key="time:timestamp" value="2024-01-04T08:00:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-04T08:30:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_2"/>
      <date key="time:timestamp" value="2024-01-04T09:00:00.000Z"/>
      <string key="org:resource" value="support_l1_b"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_2"/>
      <date key="time:timestamp" value="2024-01-04T09:15:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-04T10:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_level_3"/>
      <date key="time:timestamp" value="2024-01-04T11:00:00.000Z"/>
      <string key="org:resource" value="support_l2_a"/>
    </event>
    <event>
      <string key="concept:name" value="enter_level_3"/>
      <date key="time:timestamp" value="2024-01-04T11:30:00.000Z"/>
      <string key="org:resource" value="support_l3_b"/>
    </event>
    <event>
      <string key="concept:name" value="handle_ticket"/>
      <date key="time:timestamp" value="2024-01-04T12:30:00.000Z"/>
      <string key="org:resource" value="support_l3_b"/>
    </event>
    <event>
      <string key="concept:name" value="escalate_to_external"/>
      <date key="time:timestamp" value="2024-01-04T14:00:00.000Z"/>
      <string key="org:resource" value="support_l3_b"/>
    </event>
    <event>
      <string key="concept:name" value="external_handled"/>
      <date key="time:timestamp" value="2024-01-04T15:00:00.000Z"/>
      <string key="org:resource" value="vendor"/>

<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Data" prefix="data" uri="http://www.xes-standard.org/data.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="import_001"/>
    <event>
      <string key="concept:name" value="import_raw_data"/>
      <date key="time:timestamp" value="2024-01-01T08:00:00.000Z"/>
      <string key="data:raw_value" value="  john doe  "/>
      <string key="data:raw_email" value="JOHN@EXAMPLE.COM"/>
    </event>
    <event>
      <string key="concept:name" value="cleanse_data"/>
      <date key="time:timestamp" value="2024-01-01T08:05:00.000Z"/>
      <string key="data:clean_value" value="john doe"/>
      <string key="data:clean_email" value="john@example.com"/>
      <string key="data:cleansed" value="true"/>
    </event>
    <event>
      <string key="concept:name" value="validate_data"/>
      <date key="time:timestamp" value="2024-01-01T08:10:00.000Z"/>
      <string key="data:valid" value="true"/>
    </event>
  </trace>
</log>
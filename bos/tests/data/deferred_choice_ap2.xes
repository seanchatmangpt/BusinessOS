    <event>
      <string key="concept:name" value="path_approved"/>
      <date key="time:timestamp" value="2024-01-01T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="process_shipment"/>
      <date key="time:timestamp" value="2024-01-01T11:00:00.000Z"/>
    </event>
  </trace>

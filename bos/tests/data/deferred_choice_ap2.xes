    <event>
      <string key="concept:name" value="process_shipment"/>
      <date key="time:timestamp" value="2024-01-02T11:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 3: Both succeed → path_approved -->
  <trace>

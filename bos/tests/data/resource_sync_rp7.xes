<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Organizational" prefix="org" uri="http://www.xes-standard.org/org.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
    <string key="org:resource" value="resource"/>
  </global>
  <trace>
    <string key="concept:name" value="mtg_001"/>
    <event>
      <string key="concept:name" value="schedule_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:00:00.000Z"/>
      <string key="org:resource" value="admin"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:30:00.000Z"/>
      <string key="org:resource" value="participant_a"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:31:00.000Z"/>
      <string key="org:resource" value="participant_b"/>
    </event>
    <event>
      <string key="concept:name" value="join_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:32:00.000Z"/>
      <string key="org:resource" value="participant_c"/>
    </event>
    <event>
      <string key="concept:name" value="conduct_meeting"/>
      <date key="time:timestamp" value="2024-01-01T14:45:00.000Z"/>
      <string key="org:resource" value="admin"/>
    </event>
  </trace>
</log>
<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <extension name="Object" prefix="obj" uri="http://www.xes-standard.org/object.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case id"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <trace>
    <string key="concept:name" value="case_001"/>
    <event>
      <string key="concept:name" value="create"/>
      <date key="time:timestamp" value="2024-01-01T09:00:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:state" value="created"/>
    </event>
    <event>
      <string key="concept:name" value="activate"/>
      <date key="time:timestamp" value="2024-01-01T09:05:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:state" value="active"/>
    </event>
    <event>
      <string key="concept:name" value="process"/>
      <date key="time:timestamp" value="2024-01-01T09:30:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:state" value="processing"/>
    </event>
    <event>
      <string key="concept:name" value="complete"/>
      <date key="time:timestamp" value="2024-01-01T17:00:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:state" value="completed"/>
    </event>
    <event>
      <string key="concept:name" value="archive"/>
      <date key="time:timestamp" value="2024-01-02T09:00:00.000Z"/>
      <string key="obj:object_id" value="obj_001"/>
      <string key="obj:state" value="archived"/>
    </event>
  </trace>
</log>
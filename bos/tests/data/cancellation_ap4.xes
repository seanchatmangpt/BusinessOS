<?xml version="1.0" encoding="UTF-8"?>
<log xes.version="1.0" xes.features="nested-attributes" xmlns="http://www.xes-standard.org/">
  <extension name="Concept" prefix="concept" uri="http://www.xes-standard.org/concept.xesext"/>
  <extension name="Time" prefix="time" uri="http://www.xes-standard.org/time.xesext"/>
  <global scope="trace">
    <string key="concept:name" value="case name"/>
  </global>
  <global scope="event">
    <string key="concept:name" value="activity name"/>
    <date key="time:timestamp" value="timestamp"/>
  </global>
  <!-- Trace 1: Complete happy path -->
  <trace>
    <string key="concept:name" value="order_001"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-01T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
      <date key="time:timestamp" value="2024-01-01T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="inventory_reserved"/>
      <date key="time:timestamp" value="2024-01-01T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="shipment_prepared"/>
      <date key="time:timestamp" value="2024-01-01T11:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="order_completed"/>
      <date key="time:timestamp" value="2024-01-01T12:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 2: Complete happy path -->
  <trace>
    <string key="concept:name" value="order_002"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-02T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
      <date key="time:timestamp" value="2024-01-02T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="inventory_reserved"/>
      <date key="time:timestamp" value="2024-01-02T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="shipment_prepared"/>
      <date key="time:timestamp" value="2024-01-02T11:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="order_completed"/>
      <date key="time:timestamp" value="2024-01-02T12:00:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 3: Cancelled after inventory reserved -->
  <trace>
    <string key="concept:name" value="order_003"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-03T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
      <date key="time:timestamp" value="2024-01-03T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="inventory_reserved"/>
      <date key="time:timestamp" value="2024-01-03T10:10:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="cancellation_requested"/>
      <date key="time:timestamp" value="2024-01-03T10:20:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="inventory_released"/>
      <date key="time:timestamp" value="2024-01-03T10:25:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_refunded"/>
      <date key="time:timestamp" value="2024-01-03T10:30:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="order_cancelled"/>
      <date key="time:timestamp" value="2024-01-03T10:35:00.000Z"/>
    </event>
  </trace>
  <!-- Trace 4: Cancelled after payment -->
  <trace>
    <string key="concept:name" value="order_004"/>
    <event>
      <string key="concept:name" value="order_created"/>
      <date key="time:timestamp" value="2024-01-04T10:00:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_processed"/>
      <date key="time:timestamp" value="2024-01-04T10:05:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="cancellation_requested"/>
      <date key="time:timestamp" value="2024-01-04T10:15:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="payment_refunded"/>
      <date key="time:timestamp" value="2024-01-04T10:20:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="order_cancelled"/>
      <date key="time:timestamp" value="2024-01-04T10:25:00.000Z"/>
    </event>
  </trace>
</log>
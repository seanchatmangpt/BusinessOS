      <string key="concept:name" value="validation_pass"/>
      <date key="time:timestamp" value="2024-01-01T10:15:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="loop_exit"/>
      <date key="time:timestamp" value="2024-01-01T10:20:00.000Z"/>
    </event>
    <event>
      <string key="concept:name" value="document_approved"/>
      <date key="time:timestamp" value="2024-01-01T10:25:00.000Z"/>
    </event>
  </trace>

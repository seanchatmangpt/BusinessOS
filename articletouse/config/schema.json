{
  "version": "1.0",
  "description": "Metadata schema for AI research papers in BusinessOS articletouse system",
  "paper_metadata": {
    "id": {
      "type": "string",
      "description": "UUID v4",
      "required": true
    },
    "arxiv_id": {
      "type": "string",
      "description": "arXiv identifier (e.g., 2501.12345)",
      "required": false
    },
    "doi": {
      "type": "string",
      "description": "Digital Object Identifier",
      "required": false
    },
    "title": {
      "type": "string",
      "description": "Paper title",
      "required": true
    },
    "abstract": {
      "type": "string",
      "description": "Paper abstract/summary",
      "required": true
    },
    "authors": {
      "type": "array",
      "items": "string",
      "description": "List of author names",
      "required": true
    },
    "published_date": {
      "type": "string",
      "format": "ISO8601",
      "description": "Publication date",
      "required": true
    },
    "updated_date": {
      "type": "string",
      "format": "ISO8601",
      "description": "Last update date",
      "required": false
    },
    "source": {
      "type": "string",
      "enum": ["arxiv", "conference", "journal", "other"],
      "description": "Source of the paper",
      "required": true
    },
    "categories": {
      "type": "array",
      "items": "string",
      "description": "arXiv categories (e.g., cs.AI, cs.CL)",
      "required": false
    },
    "primary_topic": {
      "type": "string",
      "description": "Main topic classification",
      "required": true
    },
    "keywords": {
      "type": "array",
      "items": "string",
      "description": "Extracted keywords",
      "required": false
    },
    "relevance": {
      "score": {
        "type": "number",
        "min": 0,
        "max": 100,
        "description": "Overall relevance score"
      },
      "score_breakdown": {
        "technology_match": "number (0-25)",
        "feature_alignment": "number (0-30)",
        "implementation_feasibility": "number (0-20)",
        "innovation_potential": "number (0-15)",
        "recency_relevance": "number (0-10)"
      },
      "reasoning": {
        "type": "string",
        "description": "Why this paper is relevant"
      },
      "businessos_features": {
        "type": "array",
        "items": "string",
        "description": "Matched BusinessOS features"
      },
      "confidence": {
        "type": "number",
        "min": 0,
        "max": 1,
        "description": "Confidence in relevance assessment"
      }
    },
    "review_status": {
      "reviewed": {
        "type": "boolean",
        "default": false
      },
      "review_date": {
        "type": "string",
        "format": "ISO8601"
      },
      "rating": {
        "type": "integer",
        "min": 1,
        "max": 5
      },
      "summary": {
        "type": "string",
        "description": "Review summary"
      },
      "key_insights": {
        "type": "array",
        "items": "string",
        "description": "Key takeaways from the paper"
      }
    },
    "applications": {
      "type": "array",
      "items": {
        "feature_area": "string",
        "description": "string",
        "target_files": "array<string>",
        "implementation_difficulty": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "priority": {
          "type": "integer",
          "min": 1,
          "max": 10
        },
        "estimated_effort": "string",
        "impact": "string",
        "notes": "string"
      }
    },
    "files": {
      "pdf_path": "string",
      "extracted_text_path": "string",
      "notes_path": "string"
    },
    "links": {
      "arxiv_url": "string",
      "pdf_url": "string",
      "github_repo": "string",
      "project_page": "string"
    },
    "citations": {
      "count": "integer",
      "influential_citations": "integer"
    },
    "tags": {
      "type": "array",
      "items": "string",
      "description": "Custom tags for organization"
    },
    "custom_metadata": {
      "type": "object",
      "description": "Any additional metadata"
    },
    "timestamps": {
      "added": {
        "type": "string",
        "format": "ISO8601"
      },
      "last_accessed": {
        "type": "string",
        "format": "ISO8601"
      },
      "last_modified": {
        "type": "string",
        "format": "ISO8601"
      }
    }
  }
}

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"
)

// TestAuthFlow tests the complete authentication flow
func TestAuthFlow(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	ctx := context.Background()
	testDB := testutil.RequireTestDatabase(t)
	defer testDB.Close()
	defer testutil.CleanupTestData(ctx, testDB.Pool)

	queries := sqlc.New(testDB.Pool)
	logger := slog.Default()

	t.Run("Signup → Login → Get Session", func(t *testing.T) {
		// Create auth handler
		authHandler := NewAuthEmailHandler(queries, testDB.Pool, logger)
		router := gin.New()
		router.POST("/auth/signup", authHandler.Signup)
		router.POST("/auth/login", authHandler.Login)

		// Step 1: Signup
		signupReq := map[string]string{
			"email":    "newuser@example.com",
			"password": "SecurePassword123!",
			"username": "newuser",
		}

		signupBody, _ := json.Marshal(signupReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/auth/signup", bytes.NewBuffer(signupBody))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusCreated, w.Code)

		var signupResp map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &signupResp)
		require.NoError(t, err)
		assert.NotEmpty(t, signupResp["user_id"])

		// Step 2: Login
		loginReq := map[string]string{
			"email":    "newuser@example.com",
			"password": "SecurePassword123!",
		}
		loginBody, _ := json.Marshal(loginReq)
		w2 := httptest.NewRecorder()
		req2 := httptest.NewRequest("POST", "/auth/login", bytes.NewBuffer(loginBody))
		req2.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w2, req2)

		assert.Equal(t, http.StatusOK, w2.Code)

		var loginResp map[string]interface{}
		err = json.Unmarshal(w2.Body.Bytes(), &loginResp)
		require.NoError(t, err)
		assert.NotEmpty(t, loginResp["session_token"])
	})

	t.Run("Login with valid credentials", func(t *testing.T) {
		// Create test user
		userID, _ := createTestUserWithPassword(t, ctx, testDB, "valid@example.com", "password123")

		authHandler := NewAuthEmailHandler(queries, testDB.Pool, logger)
		router := gin.New()
		router.POST("/auth/login", authHandler.Login)

		loginReq := map[string]string{
			"email":    "valid@example.com",
			"password": "password123",
		}
		body, _ := json.Marshal(loginReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/auth/login", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.Equal(t, userID, response["user_id"])
		assert.NotEmpty(t, response["session_token"])
	})

	t.Run("Login with invalid credentials", func(t *testing.T) {
		authHandler := NewAuthEmailHandler(queries, testDB.Pool, logger)
		router := gin.New()
		router.POST("/auth/login", authHandler.Login)

		loginReq := map[string]string{
			"email":    "nonexistent@example.com",
			"password": "wrongpassword",
		}
		body, _ := json.Marshal(loginReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/auth/login", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusUnauthorized, w.Code)
	})

	t.Run("Logout", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)

		authHandler := NewAuthEmailHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/auth/logout", authHandler.Logout)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/auth/logout", nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		// Verify session is deleted
		pgSessionID := pgUUIDFromString(t, sessionID)
		_, err := queries.GetSessionByID(ctx, pgSessionID)
		assert.Error(t, err) // Should not find session
	})

	t.Run("Session validation", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)

		router := setupAuthRouter(userID, sessionID)
		router.GET("/protected", func(c *gin.Context) {
			uid := c.GetString("user_id")
			c.JSON(http.StatusOK, gin.H{"user_id": uid})
		})

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/protected", nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.Equal(t, userID, response["user_id"])
	})

	t.Run("Token refresh", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)

		authHandler := NewAuthEmailHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/auth/refresh", authHandler.RefreshSession)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/auth/refresh", nil)
		router.ServeHTTP(w, req)

		// Should either refresh or return current session
		assert.True(t, w.Code == http.StatusOK || w.Code == http.StatusCreated)
	})

	t.Run("Unauthorized access", func(t *testing.T) {
		router := gin.New()
		router.GET("/protected", func(c *gin.Context) {
			uid := c.GetString("user_id")
			if uid == "" {
				c.JSON(http.StatusUnauthorized, gin.H{"error": "unauthorized"})
				return
			}
			c.JSON(http.StatusOK, gin.H{"user_id": uid})
		})

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/protected", nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusUnauthorized, w.Code)
	})

	t.Run("Expired session handling", func(t *testing.T) {
		userID := uuid.New()
		sessionID := uuid.New()

		// Create user
		_, err := testDB.Pool.Exec(ctx, `
			INSERT INTO users (id, email, password_hash, username, email_verified, created_at, updated_at)
			VALUES ($1, $2, $3, $4, true, NOW(), NOW())
		`, userID, "expired@example.com", "hash", "expireduser")
		require.NoError(t, err)

		// Create expired session
		_, err = testDB.Pool.Exec(ctx, `
			INSERT INTO sessions (id, user_id, session_token, expires_at, created_at, updated_at)
			VALUES ($1, $2, $3, NOW() - INTERVAL '1 day', NOW(), NOW())
		`, sessionID, userID, "expired-token")
		require.NoError(t, err)

		// Try to use expired session
		router := setupAuthRouter(userID.String(), sessionID.String())
		router.GET("/protected", func(c *gin.Context) {
			// In production, middleware would check expiry
			c.JSON(http.StatusOK, gin.H{"user_id": c.GetString("user_id")})
		})

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/protected", nil)
		router.ServeHTTP(w, req)

		// For this test, we just verify the session exists but is expired
		pgSessionID := pgtype.UUID{Bytes: sessionID, Valid: true}
		session, err := queries.GetSessionByID(ctx, pgSessionID)
		require.NoError(t, err)
		assert.True(t, session.ExpiresAt.Time.Before(time.Now()))
	})
}

// TestMemoryCRUDWithWorkspace tests memory operations with workspace context
func TestMemoryCRUDWithWorkspace(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	ctx := context.Background()
	testDB := testutil.RequireTestDatabase(t)
	defer testDB.Close()
	defer testutil.CleanupTestData(ctx, testDB.Pool)

	queries := sqlc.New(testDB.Pool)
	logger := slog.Default()

	t.Run("Create memory → Update → Delete with workspace context", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/memories", memoryHandler.CreateMemory)
		router.PATCH("/memories/:id", memoryHandler.UpdateMemory)
		router.DELETE("/memories/:id", memoryHandler.DeleteMemory)

		// Step 1: Create memory
		createReq := map[string]interface{}{
			"title":        "Test Memory",
			"content":      "This is test memory content",
			"memory_type":  "fact",
			"workspace_id": workspaceID,
		}

		body, err := json.Marshal(createReq)
		require.NoError(t, err)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/memories", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusCreated, w.Code)

		var createResp map[string]interface{}
		err = json.Unmarshal(w.Body.Bytes(), &createResp)
		require.NoError(t, err)
		memoryID := createResp["id"].(string)
		assert.NotEmpty(t, memoryID)

		// Step 2: Update memory
		updateReq := map[string]interface{}{
			"content": "Updated memory content",
		}
		updateBody, _ := json.Marshal(updateReq)
		w2 := httptest.NewRecorder()
		req2 := httptest.NewRequest("PATCH", "/memories/"+memoryID, bytes.NewBuffer(updateBody))
		req2.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w2, req2)

		assert.Equal(t, http.StatusOK, w2.Code)

		// Step 3: Delete memory
		w3 := httptest.NewRecorder()
		req3 := httptest.NewRequest("DELETE", "/memories/"+memoryID, nil)
		router.ServeHTTP(w3, req3)

		assert.Equal(t, http.StatusNoContent, w3.Code)
	})

	t.Run("Create memory success", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/memories", memoryHandler.CreateMemory)

		createReq := map[string]interface{}{
			"title":        "New Memory",
			"content":      "Memory content",
			"memory_type":  "preference",
			"workspace_id": workspaceID,
		}

		body, _ := json.Marshal(createReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/memories", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusCreated, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.NotEmpty(t, response["id"])
		assert.Equal(t, "New Memory", response["title"])
	})

	t.Run("Create memory validation errors", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/memories", memoryHandler.CreateMemory)

		// Missing required fields
		createReq := map[string]interface{}{
			"title": "",
		}

		body, _ := json.Marshal(createReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/memories", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusBadRequest, w.Code)
	})

	t.Run("Get memory by ID", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		memoryID := createTestMemory(t, ctx, testDB, workspaceID, userID, "Get Test Memory")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.GET("/memories/:id", memoryHandler.GetMemory)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/memories/"+memoryID, nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.Equal(t, memoryID, response["id"])
		assert.Equal(t, "Get Test Memory", response["title"])
	})

	t.Run("Get memory not found", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.GET("/memories/:id", memoryHandler.GetMemory)

		fakeID := uuid.New().String()
		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/memories/"+fakeID, nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusNotFound, w.Code)
	})

	t.Run("Update memory success", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		memoryID := createTestMemory(t, ctx, testDB, workspaceID, userID, "Original Title")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.PATCH("/memories/:id", memoryHandler.UpdateMemory)

		updateReq := map[string]interface{}{
			"title":   "Updated Title",
			"content": "Updated content",
		}

		body, _ := json.Marshal(updateReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("PATCH", "/memories/"+memoryID, bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.Equal(t, "Updated Title", response["title"])
	})

	t.Run("Update memory unauthorized", func(t *testing.T) {
		userID, _ := createTestUserWithSession(t, ctx, testDB)
		otherUserID, otherSessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		memoryID := createTestMemory(t, ctx, testDB, workspaceID, userID, "Protected Memory")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(otherUserID, otherSessionID)
		router.PATCH("/memories/:id", memoryHandler.UpdateMemory)

		updateReq := map[string]interface{}{
			"title": "Hacked Title",
		}

		body, _ := json.Marshal(updateReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("PATCH", "/memories/"+memoryID, bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusForbidden, w.Code)
	})

	t.Run("Delete memory success", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		memoryID := createTestMemory(t, ctx, testDB, workspaceID, userID, "To Delete")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.DELETE("/memories/:id", memoryHandler.DeleteMemory)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("DELETE", "/memories/"+memoryID, nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusNoContent, w.Code)

		// Verify memory is deleted
		router2 := setupAuthRouter(userID, sessionID)
		router2.GET("/memories/:id", memoryHandler.GetMemory)

		w2 := httptest.NewRecorder()
		req2 := httptest.NewRequest("GET", "/memories/"+memoryID, nil)
		router2.ServeHTTP(w2, req2)

		assert.Equal(t, http.StatusNotFound, w2.Code)
	})

	t.Run("List memories with filters", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		createTestMemory(t, ctx, testDB, workspaceID, userID, "Memory 1")
		createTestMemory(t, ctx, testDB, workspaceID, userID, "Memory 2")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.GET("/memories", memoryHandler.ListMemories)

		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/memories?workspace_id="+workspaceID+"&limit=10", nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)
		assert.NotNil(t, response["memories"])
	})

	t.Run("Workspace memory isolation", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspace1 := createTestWorkspace(t, ctx, testDB, userID)
		workspace2 := createTestWorkspace(t, ctx, testDB, userID)

		memory1 := createTestMemory(t, ctx, testDB, workspace1, userID, "Workspace 1 Memory")
		createTestMemory(t, ctx, testDB, workspace2, userID, "Workspace 2 Memory")

		memoryHandler := NewMemoryHandler(queries, testDB.Pool, logger)
		router := setupAuthRouter(userID, sessionID)
		router.GET("/memories", memoryHandler.ListMemories)

		// List memories for workspace 1 only
		w := httptest.NewRecorder()
		req := httptest.NewRequest("GET", "/memories?workspace_id="+workspace1, nil)
		router.ServeHTTP(w, req)

		assert.Equal(t, http.StatusOK, w.Code)

		var response map[string]interface{}
		err := json.Unmarshal(w.Body.Bytes(), &response)
		require.NoError(t, err)

		// Verify only workspace 1 memories are returned
		memories := response["memories"].([]interface{})
		for _, mem := range memories {
			m := mem.(map[string]interface{})
			assert.Equal(t, workspace1, m["workspace_id"])
		}

		_ = memory1 // Used for validation
	})
}

// TestChatWithMemoryInjection tests chat with relevant memories included
func TestChatWithMemoryInjection(t *testing.T) {
	if testing.Short() {
		t.Skip("Skipping integration test in short mode")
	}

	ctx := context.Background()
	testDB := testutil.RequireTestDatabase(t)
	defer testDB.Close()
	defer testutil.CleanupTestData(ctx, testDB.Pool)

	queries := sqlc.New(testDB.Pool)
	logger := slog.Default()

	t.Run("Send chat message with memories included", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		conversationID := createTestConversation(t, ctx, testDB, workspaceID, userID)

		// Create memory that should be retrieved
		createTestMemory(t, ctx, testDB, workspaceID, userID, "User prefers dark mode")

		chatHandler := NewChatV2Handler(queries, testDB.Pool, logger, nil)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/chat/message", chatHandler.SendMessage)

		chatReq := map[string]interface{}{
			"message":         "What did I tell you about my preferences?",
			"conversation_id": conversationID,
			"include_memory":  true,
		}

		body, _ := json.Marshal(chatReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/chat/message", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		// SSE endpoints should return 200 and start streaming
		assert.True(t, w.Code == http.StatusOK || w.Code == http.StatusAccepted)
	})

	t.Run("Memory retrieval by relevance score", func(t *testing.T) {
		userID, _ := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)

		// Create memories with different relevance
		createTestMemory(t, ctx, testDB, workspaceID, userID, "User likes TypeScript")
		createTestMemory(t, ctx, testDB, workspaceID, userID, "User works at Acme Corp")
		createTestMemory(t, ctx, testDB, workspaceID, userID, "User prefers React")

		// In production, pgvector would filter by similarity
		// For test, we verify memories exist
		pgWorkspaceID := pgUUIDFromString(t, workspaceID)
		pgUserID := pgUUIDFromString(t, userID)

		memories, err := queries.ListMemoriesByWorkspace(ctx, sqlc.ListMemoriesByWorkspaceParams{
			WorkspaceID: pgWorkspaceID,
			UserID:      pgUserID,
			Limit:       10,
			Offset:      0,
		})
		require.NoError(t, err)
		assert.GreaterOrEqual(t, len(memories), 3)
	})

	t.Run("Memory context window limits", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)

		// Create many memories
		for i := 0; i < 20; i++ {
			createTestMemory(t, ctx, testDB, workspaceID, userID, "Memory content "+string(rune(i)))
		}

		// Memory service should limit results
		pgWorkspaceID := pgUUIDFromString(t, workspaceID)
		pgUserID := pgUUIDFromString(t, userID)

		memories, err := queries.ListMemoriesByWorkspace(ctx, sqlc.ListMemoriesByWorkspaceParams{
			WorkspaceID: pgWorkspaceID,
			UserID:      pgUserID,
			Limit:       10, // Context window limit
			Offset:      0,
		})
		require.NoError(t, err)
		assert.LessOrEqual(t, len(memories), 10)

		_ = sessionID
	})

	t.Run("Chat without memories", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		conversationID := createTestConversation(t, ctx, testDB, workspaceID, userID)

		chatHandler := NewChatV2Handler(queries, testDB.Pool, logger, nil)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/chat/message", chatHandler.SendMessage)

		chatReq := map[string]interface{}{
			"message":         "Hello",
			"conversation_id": conversationID,
			"include_memory":  false,
		}

		body, _ := json.Marshal(chatReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/chat/message", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		router.ServeHTTP(w, req)

		assert.True(t, w.Code == http.StatusOK || w.Code == http.StatusAccepted)
	})

	t.Run("SSE streaming with memories", func(t *testing.T) {
		userID, sessionID := createTestUserWithSession(t, ctx, testDB)
		workspaceID := createTestWorkspace(t, ctx, testDB, userID)
		conversationID := createTestConversation(t, ctx, testDB, workspaceID, userID)

		createTestMemory(t, ctx, testDB, workspaceID, userID, "Important context")

		chatHandler := NewChatV2Handler(queries, testDB.Pool, logger, nil)
		router := setupAuthRouter(userID, sessionID)
		router.POST("/chat/message", chatHandler.SendMessage)

		chatReq := map[string]interface{}{
			"message":         "Test with memory",
			"conversation_id": conversationID,
			"include_memory":  true,
		}

		body, _ := json.Marshal(chatReq)
		w := httptest.NewRecorder()
		req := httptest.NewRequest("POST", "/chat/message", bytes.NewBuffer(body))
		req.Header.Set("Content-Type", "application/json")
		req.Header.Set("Accept", "text/event-stream")
		router.ServeHTTP(w, req)

		// SSE streaming should start
		assert.True(t, w.Code == http.StatusOK || w.Code == http.StatusAccepted)
	})
}


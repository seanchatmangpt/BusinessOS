# Production Environment Configuration
# Copy this to .env.production and fill in your values

# ===========================================
# DATABASE (Google Cloud SQL)
# ===========================================
# Format: postgres://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@/business_os?host=/cloudsql/YOUR_PROJECT:us-central1:YOUR_INSTANCE

# ===========================================
# SERVER
# ===========================================
SERVER_PORT=8080
ENVIRONMENT=production

# ===========================================
# CORS (Your Vercel frontend domain)
# ===========================================
CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com

# ===========================================
# GOOGLE OAUTH
# Get credentials from: https://console.cloud.google.com/apis/credentials
# ===========================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Base URI for auth - handler appends "/login"
# In GCP, add these Authorized Redirect URIs:
#   - https://your-backend.run.app/api/auth/google/callback/login (for user login)
#   - https://your-backend.run.app/api/integrations/google/callback (for calendar integration)
GOOGLE_REDIRECT_URI=https://your-backend.run.app/api/auth/google/callback

# ===========================================
# AI PROVIDERS (Cloud-only for production)
# ===========================================
# Primary provider for production (ollama_local NOT available in cloud)
AI_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq (fast inference)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama Cloud (if you want cloud-hosted Ollama)
OLLAMA_CLOUD_API_KEY=your-ollama-cloud-key
OLLAMA_CLOUD_MODEL=llama3.2

# ===========================================
# REDIS (Session Storage & Pub/Sub)
# ===========================================
# For development (local Docker): redis://localhost:6379/0
# For production (Cloud Redis with TLS): rediss://your-redis-host:6380/0
REDIS_URL=redis://localhost:6379/0

# CRITICAL: Set a strong password for Redis authentication
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=your-strong-redis-password-change-this

# Enable TLS for Redis connections (required for production cloud deployments)
# Use rediss:// URL scheme when TLS is enabled
REDIS_TLS_ENABLED=false

# CRITICAL: HMAC secret for Redis key derivation (prevents token enumeration attacks)
# Generate with: openssl rand -base64 32
# This MUST be set in production to a strong random value (minimum 32 bytes)
REDIS_KEY_HMAC_SECRET=your-strong-hmac-secret-min-32-bytes

# ===========================================
# OPTIONAL: Feature Flags
# ===========================================
ENABLE_LOCAL_MODELS=false

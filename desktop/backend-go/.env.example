# Development Environment Configuration
# Copy this to .env and fill in your values

# ===========================================
# DATABASE - SUPABASE (Production/Development)
# ===========================================
# IMPORTANT: Use the POOLED connection string (port 6543), NOT direct (port 5432)
#
# To get your connection string:
# 1. Go to: https://supabase.com/dashboard/project/fuqhjbgbjamtxcdphjpp/settings/database
# 2. Scroll to "Connection string"
# 3. Select "Connection pooling" → "Transaction mode"
# 4. Copy the connection string and replace [YOUR-PASSWORD] with your actual password
#
# Format: postgres://postgres.PROJECT_ID:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true


# For local PostgreSQL development (alternative to Supabase):
# 

# ===========================================
# SERVER
# ===========================================
SERVER_PORT=8001
ENVIRONMENT=development

# ===========================================
# CORS (Local Development)
# ===========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,app://localhost

# ===========================================
# GOOGLE OAUTH
# ===========================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

# ===========================================
# REDIS (Session Storage & Pub/Sub)
# ===========================================
# Local Docker Redis with password authentication
REDIS_URL=redis://localhost:6379/0

# Redis password (matches docker-compose.yml)
# For development, you can use a simple password
# For production, generate with: openssl rand -base64 32
REDIS_PASSWORD=changeme_insecure_dev_password

# TLS disabled for local development
REDIS_TLS_ENABLED=false

# HMAC secret for Redis key derivation (prevents token enumeration)
# Generate with: openssl rand -base64 32
# For dev, you can use a simple value. For production, use a strong random value.
REDIS_KEY_HMAC_SECRET=
# ===========================================
# AI PROVIDERS (Development)
# ===========================================
# Options: "ollama_local", "ollama_cloud", "anthropic", "groq"
AI_PROVIDER=ollama_local

# Ollama Local (default for development)
OLLAMA_LOCAL_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2:3b

# Ollama Cloud (optional)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=llama3.2

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq (optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ===========================================
# OPTIONAL: Other Services
# ===========================================
SUPERMEMORY_API_KEY=

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_LOCAL_MODELS=true

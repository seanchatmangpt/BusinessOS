# Development Environment Configuration
# Copy this to .env and fill in your values

# ===========================================
# DATABASE - SUPABASE (Production/Development)
# ===========================================
# IMPORTANT: Use the POOLED connection string (port 6543), NOT direct (port 5432)
#
# To get your connection string:
# 1. Go to: https://supabase.com/dashboard/project/fuqhjbgbjamtxcdphjpp/settings/database
# 2. Scroll to "Connection string"
# 3. Select "Connection pooling" → "Transaction mode"
# 4. Copy the connection string and replace [YOUR-PASSWORD] with your actual password
#
# Format: postgres://postgres.PROJECT_ID:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true


# For local PostgreSQL development (alternative to Supabase):
# 

# ===========================================
# SERVER
# ===========================================
SERVER_PORT=8001
ENVIRONMENT=development

# ===========================================
# CORS (Local Development)
# ===========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,app://localhost

# ===========================================
# GOOGLE OAUTH (Google Workspace)
# ===========================================
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback

# ===========================================
# MICROSOFT 365 OAUTH
# ===========================================
# Get credentials at: https://portal.azure.com → Azure AD → App registrations
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8001/api/auth/microsoft/callback

# ===========================================
# SLACK OAUTH
# ===========================================
# Get credentials at: https://api.slack.com/apps
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_REDIRECT_URI=http://localhost:8001/api/auth/slack/callback
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ===========================================
# NOTION OAUTH
# ===========================================
# Get credentials at: https://www.notion.so/my-integrations
NOTION_CLIENT_ID=your-notion-client-id
NOTION_CLIENT_SECRET=your-notion-client-secret
NOTION_REDIRECT_URI=http://localhost:8001/api/auth/notion/callback

# ===========================================
# LINEAR OAUTH
# ===========================================
# Get credentials at: https://linear.app/settings/api
LINEAR_CLIENT_ID=your-linear-client-id
LINEAR_CLIENT_SECRET=your-linear-client-secret
LINEAR_REDIRECT_URI=http://localhost:8001/api/auth/linear/callback

# ===========================================
# HUBSPOT OAUTH
# ===========================================
# Get credentials at: https://developers.hubspot.com/
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_REDIRECT_URI=http://localhost:8001/api/auth/hubspot/callback

# ===========================================
# CLICKUP OAUTH
# ===========================================
# Get credentials at: https://clickup.com/api
CLICKUP_CLIENT_ID=your-clickup-client-id
CLICKUP_CLIENT_SECRET=your-clickup-client-secret
CLICKUP_REDIRECT_URI=http://localhost:8001/api/auth/clickup/callback

# ===========================================
# AIRTABLE OAUTH
# ===========================================
# Get credentials at: https://airtable.com/developers/web/api
AIRTABLE_CLIENT_ID=your-airtable-client-id
AIRTABLE_CLIENT_SECRET=your-airtable-client-secret
AIRTABLE_REDIRECT_URI=http://localhost:8001/api/auth/airtable/callback

# ===========================================
# FATHOM ANALYTICS (API Key Auth)
# ===========================================
# Get API key at: https://app.usefathom.com/api
FATHOM_API_KEY=your-fathom-api-key

# ===========================================
# SECURITY KEYS (CRITICAL FOR PRODUCTION)
# ===========================================
# JWT signing key - MUST change in production
# Generate with: openssl rand -base64 64
SECRET_KEY=your-secret-key-change-this-in-production

# Token encryption key for OAuth tokens in database
# REQUIRED in production - tokens stored in plaintext without this
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# ===========================================
# REDIS (Session Storage & Pub/Sub)
# ===========================================
# Local Docker Redis with password authentication
REDIS_URL=redis://localhost:6379/0

# Redis password (matches docker-compose.yml)
# For development, you can use a simple password
# For production, generate with: openssl rand -base64 32
REDIS_PASSWORD=changeme_insecure_dev_password

# TLS disabled for local development
REDIS_TLS_ENABLED=false

# HMAC secret for Redis key derivation (prevents token enumeration)
# Generate with: openssl rand -base64 32
# For dev, you can use a simple value. For production, use a strong random value.
REDIS_KEY_HMAC_SECRET=
# ===========================================
# AI PROVIDERS (Development)
# ===========================================
# Options: "ollama_local", "ollama_cloud", "anthropic", "groq"
AI_PROVIDER=ollama_local

# Ollama Local (default for development)
OLLAMA_LOCAL_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2:3b

# Ollama Cloud (optional)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=llama3.2

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Groq (optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ===========================================
# OPTIONAL: Other Services
# ===========================================
SUPERMEMORY_API_KEY=

# ===========================================
# EMAIL SERVICE (Resend)
# ===========================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@osa.dev
APP_URL=http://localhost:5173

# ===========================================
# WEB PUSH (VAPID)
# ===========================================
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_LOCAL_MODELS=true

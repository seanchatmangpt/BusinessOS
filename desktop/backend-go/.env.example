# ╔══════════════════════════════════════════════════════════════╗
# ║  BusinessOS - Environment Configuration                     ║
# ║  Copy to .env and fill in your values                       ║
# ║  Last rotated: 2026-02-24                                   ║
# ╚══════════════════════════════════════════════════════════════╝
#
# SETUP STEPS:
#   1. cp .env.example .env
#   2. Go to each link below and get/rotate your keys
#   3. Paste them into .env
#   4. Run: docker compose up -d
#   5. Run: go run ./cmd/server


# ═══════════════════════════════════════════════════════════════
# [1] DATABASE - Supabase
# ═══════════════════════════════════════════════════════════════
# LINK: https://supabase.com/dashboard → Your Project → Settings → Database
#   1. Reset password if rotating
#   2. Scroll to "Connection string"
#   3. Select "Connection pooling" → "Transaction mode"
#   4. Copy and replace [YOUR-PASSWORD]
#
# Format: postgres://postgres.PROJECT_ID:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# For local dev with docker-compose instead of Supabase:
# DATABASE_URL=postgres://postgres:YOUR_LOCAL_PW@localhost:5433/business_os?sslmode=disable

# Direct host (used by migration scripts to bypass pooler)
# Format: db.YOUR-PROJECT-ID.supabase.co:5432
SUPABASE_DIRECT_HOST=


# ═══════════════════════════════════════════════════════════════
# [2] SECURITY KEYS - Generate locally (no link needed)
# ═══════════════════════════════════════════════════════════════
# Run these commands and paste the output:
#
#   openssl rand -base64 64    → SECRET_KEY
#   openssl rand -base64 32    → TOKEN_ENCRYPTION_KEY
#   openssl rand -base64 32    → REDIS_PASSWORD
#   openssl rand -base64 32    → REDIS_KEY_HMAC_SECRET
#   openssl rand -base64 32    → OSA_WEBHOOK_SECRET

# JWT signing key
SECRET_KEY=

# Encryption key for OAuth tokens stored in DB
TOKEN_ENCRYPTION_KEY=

# Redis password (must match docker-compose.yml)
REDIS_PASSWORD=

# HMAC secret for Redis key derivation
REDIS_KEY_HMAC_SECRET=

# Webhook secret for OSA integration
OSA_WEBHOOK_SECRET=


# ═══════════════════════════════════════════════════════════════
# [3] GOOGLE OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://console.cloud.google.com/apis/credentials
#   1. Select your OAuth 2.0 Client
#   2. Click "Reset Secret" to rotate
#   3. Copy Client ID and new Client Secret
#   4. Verify redirect URIs include your callback URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8001/api/auth/google/callback


# ═══════════════════════════════════════════════════════════════
# [4] MICROSOFT 365 OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
#   1. Select your app registration
#   2. Go to "Certificates & secrets"
#   3. Delete old secret, create new one
#   4. Copy Application (client) ID and new secret value
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8001/api/auth/microsoft/callback


# ═══════════════════════════════════════════════════════════════
# [5] SLACK OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://api.slack.com/apps
#   1. Select your app
#   2. Go to "Basic Information" → "App Credentials"
#   3. Regenerate Client Secret and Signing Secret
#   4. Copy Client ID, new Client Secret, new Signing Secret
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8001/api/auth/slack/callback
SLACK_SIGNING_SECRET=


# ═══════════════════════════════════════════════════════════════
# [6] NOTION OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://www.notion.so/my-integrations
#   1. Select your integration
#   2. Go to "Secrets" → regenerate
#   3. Copy OAuth client ID and secret
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8001/api/auth/notion/callback


# ═══════════════════════════════════════════════════════════════
# [7] LINEAR OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://linear.app/settings/api → OAuth Applications
#   1. Select your app
#   2. Regenerate client secret
#   3. Copy Client ID and new secret
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://localhost:8001/api/auth/linear/callback


# ═══════════════════════════════════════════════════════════════
# [8] HUBSPOT OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://developers.hubspot.com/ → Your Apps
#   1. Select your app → Auth tab
#   2. Rotate Client Secret
#   3. Copy Client ID and new secret
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8001/api/auth/hubspot/callback


# ═══════════════════════════════════════════════════════════════
# [9] CLICKUP OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://app.clickup.com/settings/apps
#   1. Select your app
#   2. Regenerate secret
#   3. Copy Client ID and new secret
CLICKUP_CLIENT_ID=
CLICKUP_CLIENT_SECRET=
CLICKUP_REDIRECT_URI=http://localhost:8001/api/auth/clickup/callback


# ═══════════════════════════════════════════════════════════════
# [10] AIRTABLE OAUTH
# ═══════════════════════════════════════════════════════════════
# LINK: https://airtable.com/create/oauth
#   1. Select your integration
#   2. Regenerate client secret
#   3. Copy Client ID and new secret
AIRTABLE_CLIENT_ID=
AIRTABLE_CLIENT_SECRET=
AIRTABLE_REDIRECT_URI=http://localhost:8001/api/auth/airtable/callback


# ═══════════════════════════════════════════════════════════════
# [11] AI PROVIDERS - Rotate any keys the old team had
# ═══════════════════════════════════════════════════════════════
# Default provider for local dev (no key needed):
AI_PROVIDER=ollama_local
OLLAMA_LOCAL_URL=http://localhost:11434
DEFAULT_MODEL=llama3.2:3b

# LINK: https://console.anthropic.com/settings/keys
#   → Delete old key, create new one
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LINK: https://console.groq.com/keys
#   → Delete old key, create new one
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# LINK: https://platform.openai.com/api-keys
#   → Delete old key, create new one
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# LINK: https://console.x.ai/
#   → Delete old key, create new one
XAI_API_KEY=
XAI_MODEL=grok-beta
XAI_BASE_URL=https://api.x.ai/v1

# Ollama Cloud (optional)
# LINK: https://cloud.ollama.com (if using)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_MODEL=llama3.2


# ═══════════════════════════════════════════════════════════════
# [12] FATHOM ANALYTICS
# ═══════════════════════════════════════════════════════════════
# LINK: https://app.usefathom.com/api
#   → Regenerate API key
FATHOM_API_KEY=


# ═══════════════════════════════════════════════════════════════
# [13] EMAIL SERVICE - Resend
# ═══════════════════════════════════════════════════════════════
# LINK: https://resend.com/api-keys
#   → Delete old key, create new one
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@osa.dev
RESEND_FROM_NAME=BusinessOS
EMAIL_LOGO_URL=
SUPPORT_EMAIL=
APP_URL=http://localhost:5173


# ═══════════════════════════════════════════════════════════════
# [14] WEB PUSH - VAPID Keys
# ═══════════════════════════════════════════════════════════════
# Generate locally (no link needed):
#   npx web-push generate-vapid-keys
#   → Copy the public and private key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=


# ═══════════════════════════════════════════════════════════════
# [15] OTHER SERVICES
# ═══════════════════════════════════════════════════════════════
SUPERMEMORY_API_KEY=

# Sandbox — E2B
# LINK: https://e2b.dev/dashboard → API Keys
E2B_API_KEY=

# Voice — ElevenLabs
# LINK: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# Web Search — Brave
# LINK: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# Web Search — Serper
# LINK: https://serper.dev/api-key
SERPER_API_KEY=

# Web Search — Tavily
# LINK: https://app.tavily.com/home
TAVILY_API_KEY=


# ═══════════════════════════════════════════════════════════════
# [16] MIOSA CLOUD SYNC (optional)
# ═══════════════════════════════════════════════════════════════
# By default BusinessOS runs fully local (OSA_MODE=local, no cloud).
# To optionally sync workspace config to MIOSA Cloud:
#   1. Get your API key at https://app.miosa.ai/settings/api-keys
#   2. Set OSA_MODE=cloud
#   3. Set MIOSA_API_KEY below
#
# What syncs:   workspace settings, agent configs, app definitions, templates
# What stays local: ALL business data (tasks, contacts, deals, conversations)
#
# In Electron: set this via Settings → MIOSA Cloud, which stores the key in
# the OS keychain (keytar). The .env value is the fallback for Docker/bare-metal.

# local  = OSA runs on localhost:8089, SQLite, no cloud (default)
# cloud  = OSA connects to api.miosa.ai, PostgreSQL, cloud features
OSA_MODE=local

# LINK: https://app.miosa.ai/settings/api-keys
#   → Create a new key for this BusinessOS instance
MIOSA_API_KEY=

# Override the MIOSA Cloud endpoint (leave blank to use https://api.miosa.ai)
MIOSA_CLOUD_URL=


# ═══════════════════════════════════════════════════════════════
# SERVER & INFRASTRUCTURE (usually no rotation needed)
# ═══════════════════════════════════════════════════════════════
SERVER_PORT=8001
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,app://localhost

# Global Concurrency Control (admission control)
# Maximum concurrent HTTP requests allowed globally (default: 200)
# When exceeded, returns 503 Service Unavailable
# Prevents resource exhaustion under heavy load
GLOBAL_MAX_CONCURRENT=200

# Connection Pool Sizing (scale per environment)
# PostgreSQL: Max concurrent connections to database
# - Development (default): 25 connections for local testing
# - Production (override): 100 connections for high concurrency
PG_MAX_CONNECTIONS=

# Redis: Connection pool size for cache/pub-sub
# - Development (default): 50 connections for local testing
# - Production (override): 100 connections for high concurrency
REDIS_POOL_SIZE=

# A2A (Agent-to-Agent): Max HTTP connections per remote agent host
# - Development (default): 5 connections per host
# - Production (override): 20 connections per host for high concurrency
A2A_MAX_CONNS=

# MCP (Model Context Protocol): Max HTTP connections per MCP server host
# - Development (default): 5 connections per host
# - Production (override): 20 connections per host for high concurrency
MCP_MAX_CONNS=

# Redis connection
REDIS_URL=redis://localhost:6379/0
REDIS_TLS_ENABLED=false
REDIS_ALLOW_FLUSH=false

# Internal API authentication
INTERNAL_API_SECRET=
INTERNAL_ALLOWED_IPS=

# NATS (optional - for OSA real-time sync)
NATS_ENABLED=false
NATS_URL=nats://localhost:4222
NATS_TTL_HOURS=24

# Feature flags
ENABLE_LOCAL_MODELS=true
DISABLE_APP_DEPLOYMENT=false
WORKSPACE_PATH=/tmp/workspace


# ═══════════════════════════════════════════════════════════════
# [16] CARRIER - SORX Reasoning Bridge (RabbitMQ / AMQP)
# ═══════════════════════════════════════════════════════════════
# See docs/CARRIER-DEPLOYMENT-PLAN.md for full setup instructions.

# Master switch. Set to true only when SorxMain is available.
# When false, all carrier.Send() calls return FallbackError and BOS
# uses local LLM instead.
CARRIER_ENABLED=false

# AMQP broker URL. Use amqps:// in production.
# Local dev (docker-compose): amqp://bos:PASS@localhost:5672/
# CloudAMQP:                  amqps://user:pass@hefty-pelican.rmq.cloudamqp.com/vhost
CARRIER_AMQP_URL=amqp://bos:YOUR_RABBITMQ_PASS@localhost:5672/

# Unique identifier for this BOS instance. REQUIRED when CARRIER_ENABLED=true.
# Determines the reply queue name: sorx.responses.{OS_INSTANCE_ID}
# Must be stable across restarts. Examples:
#   Local:      bos-local-1
#   Production: bos-prod-1
#   Kubernetes: set to $(POD_NAME)
#   Fly.io:     set to bos-fly-$(FLY_ALLOC_ID)
OS_INSTANCE_ID=bos-local-1

# Optional tuning (safe to leave commented out)
# CARRIER_SEND_TIMEOUT=60s    # Max wait for synchronous Send() response
# CARRIER_PREFETCH=10         # AMQP QoS prefetch count for reply consumer

# RabbitMQ credentials for docker-compose (must match docker-compose.yml)
# Generate with: openssl rand -base64 32
RABBITMQ_USER=bos
RABBITMQ_PASS=

# ═══════════════════════════════════════════════════════════════
# [17] YAWL v6 ENGINE (optional — for conformance checking + WCP pattern loading)
# ═══════════════════════════════════════════════════════════════
# LINK: https://yawlfoundation.github.io/
#   1. Download and run YAWL v6 locally
#   2. Default endpoint is http://localhost:8080
#   3. Specs are in ~/chatmangpt/yawlv6/exampleSpecs/ (wcp-patterns + real-data)
#
# No key rotation needed — YAWL v6 is a local engine with no API key.

# YAWL v6 engine base URL (used by internal/integrations/yawlv6/client.go)
YAWLV6_URL=http://localhost:8080

# Path to exampleSpecs directory (wcp-patterns/, real-data/, processmining/)
YAWLV6_SPECS_PATH=~/chatmangpt/yawlv6/exampleSpecs


# ═══════════════════════════════════════════════════════════════
# [18] BOS GATEWAY
# ═══════════════════════════════════════════════════════════════
# Token for authenticating BOS gateway requests
BUSINESSOS_API_TOKEN=

# Write-ahead log directory for discovery result durability
BOS_WAL_DIR=/tmp/bos-wal


# ═══════════════════════════════════════════════════════════════
# [19] AUTH & COOKIES
# ═══════════════════════════════════════════════════════════════
# Domain for auth cookies (set to your production domain in prod)
COOKIE_DOMAIN=localhost

# Shared secret for signing outgoing webhooks
WEBHOOK_SIGNING_SECRET=


# ═══════════════════════════════════════════════════════════════
# [20] OSA WEBHOOK SECURITY
# ═══════════════════════════════════════════════════════════════
# Allow OSA webhooks without signature verification (disable in production)
OSA_ALLOW_UNSIGNED_WEBHOOKS=false

# Shared secret for verifying OSA webhook signatures
OSA_SHARED_SECRET=


# ═══════════════════════════════════════════════════════════════
# [21] ONTOLOGY — Oxigraph Triplestore
# ═══════════════════════════════════════════════════════════════
# SPARQL endpoint for ontology queries
OXIGRAPH_URL=http://localhost:7878

# Ontology environment context (development, staging, production)
ONTOLOGY_ENV=development


# ═══════════════════════════════════════════════════════════════
# [22] COMPLIANCE NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════
# Email address for compliance violation notifications
COMPLIANCE_NOTIFICATION_EMAIL=
